digitalWrite(ledPim,HIGH);
digitalWrite(ledPin2,LOW);
digitalWrite(ledPin3,LOW);
delay(500);

digitalWrite(ledPin,LOW);
digitalWrite(ledPim,LOW);
digitalWrite(ledPin2,HIGH);
digitalWrite(ledPin3,LOW);
delay(500);


digitalWrite(ledPin,LOW);
digitalWrite(ledPim,LOW);
digitalWrite(ledPin2,LOW);
