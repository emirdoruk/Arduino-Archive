int ledPin=4;
int ledPim=8;
int ledPin2=6;
int ledPin3=9;


void setup() {
pinMode(ledPin,OUTPUT);                                                                                                                                                                                                                                                                                                                                                                                                                    
pinMode(ledPim,OUTPUT);
pinMode(ledPin2,OUTPUT);
pinMode(ledPin3,OUTPUT);
}



void loop() {
digitalWrite(ledPin,HIGH);
digitalWrite(ledPim,LOW);
digitalWrite(ledPin2,LOW);
digitalWrite(ledPin3,LOW);
delay(500);

